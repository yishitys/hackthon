# Copy this file to .env and fill in the API key before ingesting/searching.
#
# Simplest cloud setup: OpenAI key handles both LLM calls and embeddings.
LLM_PROVIDER="openai"
LLM_API_KEY="your_openai_api_key"

# Optional: leave unset to use Cognee defaults.
# LLM_MODEL="openai/gpt-4o-mini"
AGENT_MODEL="gpt-5.2"
# AGENT_MAX_OUTPUT_TOKENS="5000"
# AGENT_REASONING_EFFORT="medium"
# EMBEDDING_PROVIDER="openai"
# EMBEDDING_MODEL="openai/text-embedding-3-small"
# EMBEDDING_API_KEY="your_openai_api_key"

# Default local stores. No external database service is needed for the hackathon demo.
VECTOR_DB_PROVIDER="lancedb"
GRAPH_DATABASE_PROVIDER="kuzu"
DATA_ROOT_DIRECTORY="C:/programming/playground/hackthon1/.cognee/data"
SYSTEM_ROOT_DIRECTORY="C:/programming/playground/hackthon1/.cognee/system"

# Optional if you ingest web URLs with Cognee scraping/Tavily flows.
# TAVILY_API_KEY="your_tavily_api_key"
